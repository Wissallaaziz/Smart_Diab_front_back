<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/soft_cyan">
            <ImageView
                android:id="@+id/historyIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_health_logo"
                app:tint="@color/primary_blue" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/historyMealName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salade César"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:id="@+id/historyDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="19 Mai 2024 • 12:30"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/historyVerdict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Autorisé"
            android:textColor="@color/accent_green"
            android:textStyle="bold"
            android:background="@drawable/circle_blue_bg"
            android:backgroundTint="@color/soft_green"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>