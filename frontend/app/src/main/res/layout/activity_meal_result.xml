<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="12dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/resultMealImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/q1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/chat_input_bg"
                android:alpha="0.3" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:background="@drawable/bg_rounded_card"
            android:elevation="16dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/resMealName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Salade de Quinoa"
                android:textColor="@color/text_primary"
                android:textSize="26sp" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/resultAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_fileName="healthy_avatar.json" />

            <TextView
                android:id="@+id/resVerdict"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/result_authorized"
                android:textColor="@color/accent_green"
                android:textSize="20sp"
                android:fontFamily="sans-serif-bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="20dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/carbs"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/resCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24g"
                        android:textColor="@color/primary_blue"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Impact"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/resImpact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bas"
                        android:textColor="@color/accent_green"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/recommendation"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:id="@+id/resAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Ce repas est excellent pour maintenir votre glycémie stable. Vous pouvez le consommer sans inquiétude."
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/finishBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Terminer"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>